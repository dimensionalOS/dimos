# Deployment environment: "prod" | "dev". Local dev MUST set "dev".
# In "prod", JWT_SECRET must be >=32 chars or the app refuses to start.
ENVIRONMENT=dev

# Cloudflare Realtime SFU
CF_TELEOP_APP_ID=your-app-id-here
CF_TELEOP_APP_SECRET=your-app-secret-here

# Auth (>=32 chars in prod)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Database (SQLite for dev, Postgres for prod)
DATABASE_URL=sqlite+aiosqlite:///./teleop.db

# Server
HOST=0.0.0.0
PORT=8450
