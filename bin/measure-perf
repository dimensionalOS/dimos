#!/usr/bin/env python3
import argparse
import json
import subprocess
import time
import psutil
import os
import signal

def get_process_group_cpu(parent_pid):
    """Sum CPU times for a process and all its currently alive descendants."""
    try:
        parent = psutil.Process(parent_pid)
        total_user = parent.cpu_times().user
        total_system = parent.cpu_times().system
        
        for child in parent.children(recursive=True):
            try:
                ctimes = child.cpu_times()
                total_user += ctimes.user
                total_system += ctimes.system
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                continue
        return total_user, total_system
    except (psutil.NoSuchProcess, psutil.AccessDenied):
        return 0, 0

def measure_perf(command, duration, output_file=None):
    print(f"Running command: {' '.join(command)}")
    print(f"Duration: {duration} seconds")

    # Start the process group
    process = subprocess.Popen(
        command,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        preexec_fn=os.setsid
    )
    
    start_time = time.perf_counter()
    
    # Wait a bit for the process to spawn its children
    time.sleep(2)
    
    initial_user, initial_system = get_process_group_cpu(process.pid)
    
    # Wait for the remaining duration
    time.sleep(max(0, duration - 2))
    
    final_user, final_system = get_process_group_cpu(process.pid)
    
    end_time = time.perf_counter()
    
    # Terminate process group
    try:
        os.killpg(os.getpgid(process.pid), signal.SIGTERM)
        process.wait(timeout=5)
    except Exception:
        try:
            os.killpg(os.getpgid(process.pid), signal.SIGKILL)
        except Exception:
            pass

    actual_duration = end_time - start_time - 2 # We only measured for duration-2 seconds
    if actual_duration <= 0:
        actual_duration = duration # Fallback

    user_cpu = final_user - initial_user
    system_cpu = final_system - initial_system
    
    # Note: If processes exited during the run, their final CPU time isn't captured by get_process_group_cpu.
    # This is a limitation of this sampling approach. For more accuracy, one could use cgroups on Linux.
    # But for CI on a self-hosted runner, this is often good enough for relative trends.

    results = {
        "command": " ".join(command),
        "measurement_duration_s": actual_duration,
        "user_cpu_s": user_cpu,
        "system_cpu_s": system_cpu,
        "total_cpu_s": user_cpu + system_cpu,
        "cpu_percentage": ((user_cpu + system_cpu) / actual_duration) * 100 if actual_duration > 0 else 0
    }
    
    print(json.dumps(results, indent=2))
    
    if output_file:
        with open(output_file, 'w') as f:
            json.dump(results, f, indent=2)

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Measure CPU performance of a command.")
    parser.add_argument("--duration", type=float, default=30.0, help="Duration to run the command in seconds.")
    parser.add_argument("--output", type=str, help="Output JSON file path.")
    parser.add_argument("command", nargs=argparse.REMAINDER, help="The command to run.")
    
    args = parser.parse_args()
    
    if not args.command:
        print("Error: No command provided.")
        exit(1)
        
    if args.command[0] == '--':
        args.command = args.command[1:]
        
    measure_perf(args.command, args.duration, args.output)
