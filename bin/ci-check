#!/usr/bin/env bash

set -euo pipefail

echo "Ensuring pip versions are correct"
no_cuda_flag=""
if ! command -v nvidia-smi &>/dev/null || ! nvidia-smi &>/dev/null; then
    no_cuda_flag="--no-extra cuda"
fi
uv sync --frozen --all-extras --no-extra dds --no-extra unitree-dds $no_cuda_flag
uv pip install mypy

echo "Running pre-commit checks"
time pre-commit run --all-files

echo "Running mypy checks"
time uv run mypy --python-version 3.10 dimos
time uv run mypy --python-version 3.12 dimos
