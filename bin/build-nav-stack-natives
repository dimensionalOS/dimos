#!/usr/bin/env python3
"""Pre-build native modules ready for tests."""

from concurrent.futures import ProcessPoolExecutor, as_completed
import importlib
from pathlib import Path
import re
import subprocess

from dimos.core.native_module import NativeModuleConfig
import dimos.navigation.nav_stack.modules as modules_pkg

MODULES_DIR = Path(modules_pkg.__path__[0])
# Pre-filter source files for a NativeModuleConfig subclass before importing
# them. Lets us run with a minimal dimos install: modules that don't subclass
# NativeModuleConfig (e.g. nav_record) may pull in heavy deps like torch at
# top-level import, and we don't want to require those just to discover.
_HAS_NATIVE_CONFIG = re.compile(r"^class\s+\w+\s*\(\s*NativeModuleConfig\b", re.MULTILINE)


def discover() -> tuple[type[NativeModuleConfig], ...]:
    found: list[type[NativeModuleConfig]] = []
    for pkg_dir in sorted(MODULES_DIR.iterdir()):
        if not pkg_dir.is_dir():
            continue
        leaf = pkg_dir.name
        src = pkg_dir / f"{leaf}.py"
        if not src.exists() or not _HAS_NATIVE_CONFIG.search(src.read_text()):
            continue
        mod = importlib.import_module(f"{modules_pkg.__name__}.{leaf}.{leaf}")
        for attr in vars(mod).values():
            if (
                isinstance(attr, type)
                and attr is not NativeModuleConfig
                and issubclass(attr, NativeModuleConfig)
                and attr.__module__ == mod.__name__
                and attr.model_fields["build_command"].default is not None
            ):
                found.append(attr)
    return tuple(found)


def build_one(cfg_cls: type[NativeModuleConfig]) -> str:
    cfg = cfg_cls()
    assert cfg.build_command is not None
    mod = importlib.import_module(cfg_cls.__module__)
    base_dir = Path(mod.__file__).resolve().parent  # type: ignore[arg-type]
    cwd = Path(cfg.cwd) if cfg.cwd is not None else base_dir
    if not cwd.is_absolute():
        cwd = base_dir / cwd
    exe = Path(cfg.executable)
    if not exe.is_absolute():
        exe = cwd / exe
    if exe.exists():
        return f"OK:    {cfg_cls.__name__} already built at {exe}"
    header = f"BUILD: {cfg_cls.__name__} in {cwd}: {cfg.build_command}"
    proc = subprocess.run(
        cfg.build_command,
        shell=True,
        cwd=str(cwd),
        capture_output=True,
        text=True,
        check=False,
    )
    body = (proc.stdout or "") + (proc.stderr or "")
    if proc.returncode != 0:
        raise RuntimeError(f"{header}\n{body}\n{cfg_cls.__name__} exited {proc.returncode}")
    return f"{header}\n{body}".rstrip()


def main() -> None:
    cfgs = discover()
    failed = 0
    # One worker per module: builds are I/O-bound (each blocks on `nix build`),
    # so processes and threads behave the same — processes give cleaner output
    # isolation. Per-build stdout/stderr is captured and flushed as a single
    # block once the build completes, so logs stay readable.
    with ProcessPoolExecutor(max_workers=len(cfgs)) as ex:
        futs = {ex.submit(build_one, c): c for c in cfgs}
        for fut in as_completed(futs):
            try:
                print(fut.result(), flush=True)
            except Exception as e:
                print(f"FAIL:  {futs[fut].__name__}: {e}", flush=True)
                failed += 1
    if failed:
        raise SystemExit(f"{failed} build(s) failed")


if __name__ == "__main__":
    main()
