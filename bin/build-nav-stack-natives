#!/usr/bin/env python3
"""Pre-build native modules ready for tests.

Discovers every nav_stack module that defines a NativeModuleConfig with a
`build_command` set, then runs that command. CI invokes this after installing
Nix + the Cachix substituter so warm-cache builds are near-instant.

IMPORTANT: this script *statically parses* each module's `.py` source — it
does NOT import dimos. That keeps it runnable from a bare `python3` (no uv
or `pip install dimos`), saving ~30s of install overhead in CI. The trade-off
is that the regexes below pin a specific shape for how a NativeModuleConfig
declares its three relevant defaults:

    cwd: str | None = str(Path(__file__).resolve().parent)
    cwd: str | None = str(Path(__file__).resolve().parent / "<subdir>")
    cwd: str | None = "<literal>"
    executable: str = "<literal>"
    build_command: str | None = "<literal>"           # possibly
    build_command: str | None = ("<literal>")          #   parenthesised

If a config moves to a non-literal default (a function call, a format string,
etc.) this script silently skips that module. Test locally after any change
to a NativeModuleConfig.
"""

from concurrent.futures import ProcessPoolExecutor, as_completed
import os
from pathlib import Path
import re
import subprocess
import sys
import time

REPO_ROOT = Path(__file__).resolve().parent.parent
MODULES_DIR = REPO_ROOT / "dimos" / "navigation" / "nav_stack" / "modules"

_T0 = time.monotonic()


def _log(msg: str) -> None:
    print(f"[{time.monotonic() - _T0:6.1f}s] {msg}", flush=True)


_HAS_NATIVE_CONFIG = re.compile(r"^class\s+\w+\s*\(\s*NativeModuleConfig\b", re.MULTILINE)
_BUILD_CMD = re.compile(
    r'build_command:\s*str\s*\|\s*None\s*=\s*\(?\s*"([^"]+)"',
)
_BUILD_CMD_NONE = re.compile(r"build_command:\s*str\s*\|\s*None\s*=\s*None\b")
_BUILD_CMD_ANY = re.compile(r"^\s+build_command:", re.MULTILINE)
_EXECUTABLE = re.compile(r'executable:\s*str\s*=\s*"([^"]+)"')
_CWD_PARENT_SUBDIR = re.compile(
    r'cwd:\s*str\s*\|\s*None\s*=\s*str\(\s*Path\(__file__\)\.resolve\(\)\.parent\s*/\s*"([^"]+)"\s*\)'
)
_CWD_PARENT = re.compile(
    r"cwd:\s*str\s*\|\s*None\s*=\s*str\(\s*Path\(__file__\)\.resolve\(\)\.parent\s*\)"
)
_CWD_LITERAL = re.compile(r'cwd:\s*str\s*\|\s*None\s*=\s*"([^"]+)"')
_CWD_NONE = re.compile(r"cwd:\s*str\s*\|\s*None\s*=\s*None\b")
_CWD_ANY = re.compile(r"^\s+cwd:", re.MULTILINE)


class _ConfigParseError(Exception):
    pass


def _resolve_cwd(text: str, pkg_dir: Path) -> Path:
    if (sub := _CWD_PARENT_SUBDIR.search(text)) is not None:
        return pkg_dir / sub.group(1)
    if _CWD_PARENT.search(text):
        return pkg_dir
    if (lit := _CWD_LITERAL.search(text)) is not None:
        literal = lit.group(1)
        return pkg_dir if literal == "." else pkg_dir / literal
    # No literal pattern matched. An explicit `= None` (or no override at all)
    # is fine — falls back to the module's source dir, matching NativeModule's
    # own init logic.
    if _CWD_NONE.search(text) or not _CWD_ANY.search(text):
        return pkg_dir
    raise _ConfigParseError("cwd is set in an unrecognised form")


def discover() -> list[tuple[str, str, Path, Path]]:
    """Return (name, build_command, cwd, expected_exe) for each native module.

    Raises SystemExit if a file declares a NativeModuleConfig subclass with
    fields that don't match the patterns we support — better to fail loudly
    than silently skip a module the test suite was relying on.
    """
    found: list[tuple[str, str, Path, Path]] = []
    problems: list[str] = []
    for pkg_dir in sorted(MODULES_DIR.iterdir()):
        if not pkg_dir.is_dir():
            continue
        src = pkg_dir / f"{pkg_dir.name}.py"
        if not src.exists():
            continue
        text = src.read_text()
        if not _HAS_NATIVE_CONFIG.search(text):
            continue
        rel = src.relative_to(REPO_ROOT)
        bc = _BUILD_CMD.search(text)
        if not bc:
            # Either no build_command override (skip silently — module doesn't
            # need building) or an unparseable one (loud failure).
            if _BUILD_CMD_ANY.search(text) and not _BUILD_CMD_NONE.search(text):
                problems.append(
                    f"{rel}: NativeModuleConfig subclass declares build_command in "
                    "an unrecognised form — refactor to a string literal or update "
                    "bin/build-nav-stack-natives's regexes."
                )
            continue
        exe_m = _EXECUTABLE.search(text)
        if not exe_m:
            problems.append(
                f"{rel}: NativeModuleConfig declares build_command but no "
                'parseable `executable: str = "…"` literal.'
            )
            continue
        try:
            cwd = _resolve_cwd(text, pkg_dir)
        except _ConfigParseError as e:
            problems.append(f"{rel}: {e}")
            continue
        exe = Path(exe_m.group(1))
        if not exe.is_absolute():
            exe = cwd / exe
        found.append((pkg_dir.name, bc.group(1), cwd, exe))
    if problems:
        raise SystemExit("\n".join(problems))
    return found


def build_one(entry: tuple[str, str, Path, Path]) -> str:
    name, cmd, cwd, exe = entry
    if exe.exists():
        return f"OK:    {name} already built at {exe}"
    _log(f"START: {name} in {cwd}: {cmd}")
    proc = subprocess.run(
        cmd,
        shell=True,
        cwd=str(cwd),
        capture_output=True,
        text=True,
        check=False,
    )
    body = (proc.stdout or "") + (proc.stderr or "")
    if proc.returncode != 0:
        raise RuntimeError(f"{name} exited {proc.returncode}\n{body}")
    return f"DONE:  {name}\n{body}".rstrip()


def main() -> None:
    entries = discover()
    failed = 0
    # One worker per logical CPU. The original cap of 2 was working around
    # GH-hosted ubuntu-latest's ~14 GB free disk being eaten by 6 concurrent
    # nar extractions; the `free-disk-space` step in CI now reclaims ~25 GB
    # before this runs, so disk is no longer the binding constraint and we
    # can scale with cores.
    workers = os.cpu_count() or 2
    _log(f"Building {len(entries)} module(s) with up to {workers} workers")
    with ProcessPoolExecutor(max_workers=workers) as ex:
        futs = {ex.submit(build_one, e): e for e in entries}
        for fut in as_completed(futs):
            try:
                _log(fut.result())
            except Exception as e:
                _log(f"FAIL:  {futs[fut][0]}: {e}")
                failed += 1
    if failed:
        sys.exit(f"{failed} build(s) failed")


if __name__ == "__main__":
    main()
