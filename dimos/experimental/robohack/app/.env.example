# ─────────────────────────────────────────────────────────────────────────
# apps/server — the backend. Owns auth, DB, uploads, and all secrets.
# Copy to apps/server/.env for local dev. In production these are set on the
# Railway `server` service.
# ─────────────────────────────────────────────────────────────────────────

# REQUIRED — Postgres connection string (auth tables + messages).
# Local dev: `bun run db:start` brings up Postgres 17 on localhost:54324.
# Production: Railway injects ${{Postgres.DATABASE_URL}} automatically.
DATABASE_URL=postgresql://postgres:postgres@localhost:54325/robomoo

# REQUIRED — Better Auth secret. 32+ random bytes:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public origin the browser sees (the Caddy gateway). Better Auth uses it as
# baseURL + trustedOrigin. Local: gateway on :4470. Prod: the Railway domain.
APP_URL=http://localhost:4470

# Object storage (S3-compatible). Consumed by Bun.s3 in the server.
# Local dev: the MinIO container from `bun run db:start` (see docker-compose).
# Production: the Railway bucket credentials.
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=robomoo

# Shared secret the robot sends (Authorization: Bearer) to POST frames to
# /api/robot/frame. If unset, the ingest endpoint rejects everything. Generate:
#   openssl rand -hex 24
ROBOT_INGEST_TOKEN=

PORT=4471
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────
# apps/web — Next.js frontend. No secrets. Copy to apps/web/.env.
# ─────────────────────────────────────────────────────────────────────────

# Server-internal RPC URL used during SSR (no window → can't use the gateway
# origin). Local default is the server port; in production set to the internal
# address, e.g. http://server.railway.internal:4471
RPC_INTERNAL_URL=http://localhost:4471

PORT=4472

# ─── ERC-8004 (agent marketplace) — all public, browser-side ────────────────
# Identity Registry on Ethereum Sepolia. Default is the verified reference
# deployment (ChaosChain/trustless-agents-erc-ri); override only if you deploy
# your own.
NEXT_PUBLIC_ERC8004_IDENTITY_ADDRESS=0xf66e7CBdAE1Cb710fee7732E4e1f173624e137A7
# Reputation Registry on Ethereum Sepolia. REQUIRED for on-chain reputation
# reads/writes (getSummary / giveFeedback). When unset, the UI falls back to
# job-derived reputation and the demo still works. Fill from the reference repo's
# Sepolia deployment. e.g. 0x...
NEXT_PUBLIC_ERC8004_REPUTATION_ADDRESS=
# Optional custom Sepolia RPC (else viem's public default is used).
NEXT_PUBLIC_SEPOLIA_RPC_URL=
# Set to "true" to label payments as x402 (Base Sepolia). Payment is mocked for
# the MVP regardless; this only changes the copy.
NEXT_PUBLIC_X402_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────
# apps/gateway — Caddy reverse proxy (the only public service). Set on the
# Railway `gateway` service:
#   PORT=4470
#   SERVER_URL=http://server.railway.internal:4471
#   WEB_URL=http://web.railway.internal:4472
# ─────────────────────────────────────────────────────────────────────────
