{
  "workspace": ["./app", "./packages/topics", "./packages/react"],
  "nodeModulesDir": "auto",
  "exclude": ["app", "node_modules", "dist"],
  "imports": {
    "@dimos/msgs": "npm:@jsr/dimos__msgs@0.1.4",
    "@eclipse-zenoh/zenoh-ts": "npm:@eclipse-zenoh/zenoh-ts@1.9.0",
    "react": "npm:react@^18.3.1",
    "react-dom": "npm:react-dom@^18.3.1",
    "@types/react": "npm:@types/react@^18.3.12"
  },
  "fmt": {
    "lineWidth": 100,
    "exclude": ["node_modules", "dist", "app/dist", "**/*.md", "bench/results*.json"]
  },
  "lint": {
    "rules": {
      "exclude": ["no-explicit-any"]
    },
    "exclude": ["node_modules", "dist", "app"]
  },
  "tasks": {
    "app": "cd app && deno run -A npm:vite",
    "build": "cd app && deno run -A npm:vite build",
    "preview": "cd app && deno run -A npm:vite preview",
    "serve": "uv run python -m gateway",
    "dtop": "deno run -A cli/dtop.ts",
    "check": "deno check cli/*.ts bench/*.ts packages/topics/src/**/*.ts packages/react/src/**/*.tsx && cd app && deno run -A npm:typescript/tsc --noEmit -p tsconfig.json",
    "bench": "deno run -A bench/bench.ts",
    "bench:deno": "deno run -A --node-modules-dir bench/bench_deno.ts",
    "bench:matrix": "bash bench/matrix.sh",
    "bench:decode": "bash bench/decode.sh",
    "bench:webrtc": "bash bench/webrtc.sh",
    "bench:qos": "bash bench/qos.sh",
    "bench:webtransport": "bash bench/webtransport.sh",
    "bench:loss": "bash bench/loss.sh",
    "demo:qos": "bash bench/qos_demo.sh",
    "scope:nav": "DIMOS_TRANSPORT=zenoh uv run python scenarios/nav.py",
    "scope:arm": "DIMOS_TRANSPORT=zenoh uv run python scenarios/arm.py",
    "scope:cam": "DIMOS_TRANSPORT=zenoh uv run python scenarios/cam.py",
    "scope:bench": "bash scenarios/bench.sh",
    "bench:all": "deno task test && deno task bench:matrix && deno task bench:decode && deno task bench:webrtc && deno task bench:qos && deno task bench:webtransport && deno task bench:loss",
    "netsim": "deno run -A bench/netsim.ts",
    "smoke": "deno run -A bench/sdk_smoke.ts",
    "teleop:test": "deno run -A bench/teleop_test.ts",
    "test": "deno test -A --node-modules-dir packages/topics/src/ cli/",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "sim": "DIMOS_TRANSPORT=zenoh uv run dimos --simulation mujoco run unitree-go2",
    "sim:dimsim": "DIMOS_TRANSPORT=zenoh uv run dimos --simulation dimsim run unitree-go2",
    "sim:replay": "DIMOS_TRANSPORT=zenoh uv run dimos --replay run unitree-go2"
  }
}
