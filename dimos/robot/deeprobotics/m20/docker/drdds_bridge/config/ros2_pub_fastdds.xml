<?xml version="1.0" encoding="UTF-8" ?>
<!-- FastDDS 2.6 profile for ros2_pub: large SHM segment for 3MB lidar messages.
     Default SHM is 512KB — too small, causes UDP fallback + fragment loss.
     With 16MB segment, 3MB messages fit in SHM unfragmented = zero loss. -->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">

    <transport_descriptors>
        <transport_descriptor>
            <transport_id>shm_large</transport_id>
            <type>SHM</type>
            <segment_size>16777216</segment_size>
            <maxMessageSize>4194304</maxMessageSize>
        </transport_descriptor>
    </transport_descriptors>

    <participant profile_name="participant_profile" is_default_profile="true">
        <rtps>
            <useBuiltinTransports>true</useBuiltinTransports>
            <userTransports>
                <transport_id>shm_large</transport_id>
            </userTransports>
        </rtps>
    </participant>

    <data_writer profile_name="default_datawriter" is_default_profile="true">
        <qos>
            <reliability>
                <kind>BEST_EFFORT</kind>
            </reliability>
            <durability>
                <kind>VOLATILE</kind>
            </durability>
            <publishMode>
                <kind>ASYNCHRONOUS</kind>
            </publishMode>
        </qos>
        <historyMemoryPolicy>PREALLOCATED_WITH_REALLOC</historyMemoryPolicy>
        <topic>
            <historyQos>
                <kind>KEEP_LAST</kind>
                <depth>1</depth>
            </historyQos>
        </topic>
    </data_writer>

</profiles>
