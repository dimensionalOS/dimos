<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Unified FastDDS profile for ALL ROS2 processes in the M20 nav container.
  Used by FAST_LIO, ros2_pub, and any other ROS2 nodes.

  Mounted into the container at /ros2_ws/config/fastdds.xml via
  M20ROSNavConfig.docker_volumes.

  Design rationale (see ROSNAV_MIGRATION_LOG.md):
  - useBuiltinTransports=true: enables builtin SHM discovery so
    ros2_pub and FAST_LIO discover each other inside the container.
    Also enables UDP multicast for /IMU from AOS yesense.  (Finding #28)
  - shm_large (32MB): default SHM is 512KB, too small for 3MB lidar
    messages — causes UDP fallback + fragment loss.              (Finding #12)
  - transport_descriptors BEFORE participant: FastDDS 2.6 parses
    sequentially; forward refs to transport IDs cause errors.    (Finding #18)
  - <profiles> root element (not <dds><profiles>): most compatible
    with FastDDS 2.6 XML parser in ROS2 Humble.
  - maxMessageSize camelCase: FastDDS 2.6 uses camelCase, 2.14 uses
    snake_case. Wrong case silently falls back to defaults.      (Finding #17)
-->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">

    <transport_descriptors>
        <!-- Large SHM for 3MB lidar messages without UDP fallback (Finding #12).
             32MB segment fits multiple frames in flight. -->
        <transport_descriptor>
            <transport_id>shm_large</transport_id>
            <type>SHM</type>
            <segment_size>33554432</segment_size>
            <maxMessageSize>4194304</maxMessageSize>
        </transport_descriptor>
    </transport_descriptors>

    <participant profile_name="participant_profile" is_default_profile="true">
        <rtps>
            <!-- Builtin transports = default SHM + UDP.
                 SHM: intra-container discovery (ros2_pub ↔ ARISE/FAST_LIO)
                 UDP: external discovery (/IMU from yesense on NOS host) -->
            <useBuiltinTransports>true</useBuiltinTransports>
            <!-- Add large SHM on top of builtins for lidar data -->
            <userTransports>
                <transport_id>shm_large</transport_id>
            </userTransports>
            <builtin>
                <initialPeersList>
                    <!-- localhost: needed for intra-container lifecycle service discovery -->
                    <locator>
                        <udpv4>
                            <address>127.0.0.1</address>
                        </udpv4>
                    </locator>
                    <!-- NOS host: yesense publishes /IMU via drdds (FastDDS 2.14) -->
                    <locator>
                        <udpv4>
                            <address>10.21.31.106</address>
                        </udpv4>
                    </locator>
                </initialPeersList>
            </builtin>
        </rtps>
    </participant>

</profiles>
